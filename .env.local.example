# Copy this file to .env.local and fill in your Supabase project values.
# Find these in your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key is used ONLY in server-side code (never exposed to browser).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Public site URL — required on VPS to override localhost origin behind a reverse proxy.
NEXT_PUBLIC_SITE_URL=https://your-domain.com
